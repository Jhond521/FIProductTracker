server {
    listen 80;
    server_name _;
    root /usr/share/nginx/html;
    index index.html;

    # Railway's internal DNS reassigns the backend's IP on every redeploy.
    # A static (non-variable) proxy_pass resolves the hostname once at nginx
    # startup and caches it for the worker's lifetime, so it goes on
    # proxying to a dead IP after the backend restarts. Resolving through a
    # variable forces nginx to re-resolve on this ttl instead.
    resolver ${NGINX_LOCAL_RESOLVERS} valid=10s;

    # Proxying the API through this same origin (rather than the browser
    # calling the backend's own host directly) keeps auth same-site, so the
    # session cookie isn't subject to third-party cookie blocking.
    location /api/ {
        # A variable-resolved proxy_pass does not do the usual
        # location-prefix substitution: it forwards exactly the literal
        # path written here, dropping the rest of the client's URI. Append
        # $request_uri explicitly to pass the full original path through.
        set $backend_upstream ${BACKEND_INTERNAL_URL};
        proxy_pass $backend_upstream$request_uri;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location / {
        try_files $uri $uri/ /index.html;
    }
}
