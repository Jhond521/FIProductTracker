# Used by `docker compose up` to fill in ${VAR} substitutions in docker-compose.yml.
# Copy to `.env` in this same directory (repo root) and fill in real values.
#
# Google Cloud Console > APIs & Services > Credentials > OAuth Client ID (Web application)
# Authorized JavaScript origin: http://localhost:5174 (the dockerized frontend's port)
# Both vars below must be set to the SAME Client ID — one is read by the backend
# (to verify the token's audience), the other is baked into the frontend build.
GOOGLE_CLIENT_ID=
VITE_GOOGLE_CLIENT_ID=

# Secret used to sign our own session JWTs (not related to Google). Generate a real
# random value for any non-dev environment, e.g.: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=dev-only-insecure-secret-change-me
