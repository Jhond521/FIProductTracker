DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/credittracker
ENVIRONMENT=dev

# Google Cloud Console > APIs & Services > Credentials > OAuth Client ID (Web application)
# Authorized JavaScript origin: http://localhost:5173
GOOGLE_CLIENT_ID=

# Secret used to sign our own session JWTs (not related to Google). Generate a real
# random value for any non-dev environment, e.g.: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=dev-only-insecure-secret-change-me

# Leave both unset for local dev (frontend/backend share the "localhost" site over
# plain http). If frontend and backend are deployed on different hosts/subdomains
# (e.g. separate Railway services), set:
#   SESSION_COOKIE_SAMESITE=none
#   SESSION_COOKIE_SECURE=true
# — otherwise the session cookie is silently dropped on cross-site requests.
SESSION_COOKIE_SAMESITE=lax
SESSION_COOKIE_SECURE=false
